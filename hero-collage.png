export default async function handler(req, res) {
  if (req.method !== 'POST') {
    return res.status(405).json({ ok: false, error: 'Method not allowed' });
  }

  const token = process.env.TELEGRAM_BOT_TOKEN;
  const chatId = process.env.TELEGRAM_CHAT_ID;

  if (!token || !chatId) {
    return res.status(500).json({ ok: false, error: 'Telegram environment variables are not configured' });
  }

  const {
    name = 'Не указано',
    contact = 'Не указано',
    grade = 'Не указано',
    volume = 'Не указано',
    distance = 'Не указано',
    comment = 'Не указано',
    estimated = 0,
    deliveryPrice = 0,
    totalWithDelivery = 0,
    page = '',
  } = req.body || {};

  const rub = (value) => Number(value || 0).toLocaleString('ru-RU');

  const text = [
    '🚧 Новая заявка с сайта Бетонсервис',
    '',
    `👤 Имя: ${name}`,
    `📞 Контакт: ${contact}`,
    `🏗 Марка: ${grade}`,
    `📦 Объём: ${volume} м³`,
    `📍 Расстояние: ${distance} км`,
    `💬 Комментарий: ${comment}`,
    '',
    `💰 Бетон: ${rub(estimated)} ₽`,
    `🚚 Доставка: ${rub(deliveryPrice)} ₽`,
    `✅ Итого ориентировочно: ${rub(totalWithDelivery)} ₽`,
    '',
    page ? `🌐 Страница: ${page}` : '',
  ].filter(Boolean).join('\n');

  try {
    const telegramResponse = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        chat_id: chatId,
        text,
        disable_web_page_preview: true,
      }),
    });

    const data = await telegramResponse.json();

    if (!telegramResponse.ok || !data.ok) {
      return res.status(502).json({ ok: false, error: data.description || 'Telegram API error' });
    }

    return res.status(200).json({ ok: true });
  } catch (error) {
    return res.status(500).json({ ok: false, error: 'Failed to send Telegram message' });
  }
}
